---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pic from '../../../components/Pic.astro';
import { metroEn as metro, lieuxEn as lieux } from '../../../data/lieux.en.js';
import { useTranslations } from '../../../i18n/ui.js';

const mapPoints = lieux.map((lieu) => ({
  slug: lieu.slug,
  title: lieu.title,
  tagline: lieu.tagline,
  coords: lieu.coords,
  cover: lieu.cover,
}));
const base = import.meta.env.BASE_URL;
const t = useTranslations('en');
---

<BaseLayout title={t.seDeplacer.title} description={t.seDeplacer.description}>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  <section class="hero lieu-hero">
    <div class="hero-media">
      <Pic file="metro--panneau-art-nouveau" alt="Art Nouveau-style Métro sign" loading="eager" fetchpriority="high" />
    </div>
    <div class="hero-content">
      <span class="eyebrow">{t.seDeplacer.heroEyebrow}</span>
      <h1>{t.seDeplacer.heroTitle}</h1>
      <p>{t.seDeplacer.heroText}</p>
    </div>
  </section>

  <section class="container">
    <a class="back-link" href={`${base}en/`}><span class="back-arrow">←</span> {t.seDeplacer.backHome}</a>

    <div class="chapter-label" data-reveal="up">
      <span class="chapter-num">I</span>
      <span class="chapter-title">{t.seDeplacer.chapterOne}</span>
    </div>

    <div class="lieu-body">
      <div class="lieu-text">
        <p class="lieu-intro" data-reveal="up">{t.seDeplacer.introP1}</p>
        <p data-reveal="up">{t.seDeplacer.introP2}</p>
        <p data-reveal="up">{t.seDeplacer.introP3}</p>
      </div>
      <aside class="lieu-tip" data-reveal="pop">
        <span class="eyebrow">{t.seDeplacer.bonASavoir}</span>
        <p>{t.seDeplacer.tip}</p>
      </aside>
    </div>

    <div class="chapter-label" data-reveal="up">
      <span class="chapter-num">II</span>
      <span class="chapter-title">{t.seDeplacer.chapterTwo}</span>
    </div>
    <p data-reveal="up">
      {t.seDeplacer.mapIntro}
    </p>

    <div class="map-layout" data-reveal="up">
      <div id="lieu-map" class="map-shell" data-points={JSON.stringify(mapPoints)} data-base={base} data-itineraire-label={t.seDeplacer.itineraire}></div>
      <div class="map-list" id="lieu-map-list">
        {mapPoints.map((point) => (
          <button class="map-list-item" type="button" data-slug={point.slug}>
            <span class="dot"></span>
            <span>
              <strong>{point.title}</strong>
              <span>{point.tagline}</span>
            </span>
          </button>
        ))}
      </div>
    </div>

    <div class="chapter-label" data-reveal="up">
      <span class="chapter-num">III</span>
      <span class="chapter-title">{t.seDeplacer.chapterThree}</span>
    </div>
    <div class="gallery-mosaic">
      {metro.map((img) => (
        <figure data-reveal="pop">
          <Pic file={img.file} alt={img.alt} />
          <figcaption>{img.caption}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" is:inline></script>
  <script src={`${base}scripts/map.js`} data-astro-rerun is:inline></script>
</BaseLayout>
