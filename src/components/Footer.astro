---
import { useTranslations } from '../i18n/ui.js';

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const locale = Astro.currentLocale ?? 'fr';
const t = useTranslations(locale);
const localePrefix = locale === 'fr' ? '' : 'en/';
const homeHref = `${base}${localePrefix}`;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a class="site-logo" href={homeHref}>
        <img src={`${base}logo/logo-mark-light.png`} alt="Mon Voyage à Paris" width="95" height="96" />
        <span class="site-logo-title">Mon Voyage<br />à Paris</span>
      </a>
      <p>{t.footer.brandText}</p>
    </div>

    <div class="footer-col">
      <span class="footer-heading">{t.footer.exploreHeading}</span>
      <ul>
        <li><a href={`${homeHref}#lieux`}>{t.nav.lieux}</a></li>
        <li><a href={`${homeHref}#ambiance`}>{t.nav.ambiance}</a></li>
        <li><a href={`${base}${localePrefix}guide/se-deplacer`}>{t.nav.seDeplacer}</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <span class="footer-heading">{t.footer.infoHeading}</span>
      <ul>
        <li><a href={`${base}${localePrefix}mentions-legales`}>{t.footer.mentionsLegales}</a></li>
        <li><a href={`${base}${localePrefix}confidentialite`}>{t.footer.confidentialite}</a></li>
        <li><a href={`${base}${localePrefix}contact`}>{t.footer.contact}</a></li>
      </ul>
    </div>

    <div class="footer-col footer-contact">
      <span class="footer-heading">{t.footer.contactHeading}</span>
      <ul>
        <li><a href="mailto:berdierchrisnael@gmail.com">berdierchrisnael@gmail.com</a></li>
        <li><a href="tel:+33690941449">06 90 94 14 49</a></li>
        <li><a href="https://yui971.github.io/portfolio-berdier-chrisnael/" target="_blank" rel="noopener">{t.footer.portfolio}</a></li>
      </ul>
      <p class="footer-availability">{t.footer.availability}</p>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {t.footer.copyright}</p>
    <p>{t.footer.photoCredit}</p>
  </div>
</footer>
