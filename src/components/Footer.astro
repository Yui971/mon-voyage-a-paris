    </div>

    <div class="footer-col">
      <span class="footer-heading">Explorer</span>
      <ul>
        <li><a href={`${base}#lieux`}>Les lieux</a></li>
        <li><a href={`${base}#ambiance`}>Ambiance</a></li>
        <li><a href={`${base}guide/se-deplacer`}>Se déplacer</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <span class="footer-heading">Informations</span>
      <ul>
        <li><a href={`${base}mentions-legales`}>Mentions légales</a></li>
        <li><a href={`${base}confidentialite`}>Politique de confidentialité</a></li>
        <li><a href={`${base}contact`}>Contact</a></li>
      </ul>
    </div>

    <div class="footer-col footer-contact">
