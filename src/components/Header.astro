---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations } from '../i18n/ui.js';

const base = import.meta.env.BASE_URL;
const locale = Astro.currentLocale ?? 'fr';
const t = useTranslations(locale);
const localePrefix = locale === 'fr' ? '' : 'en/';
const homeHref = `${base}${localePrefix}`;

const nav = [
  { href: `${homeHref}#lieux`, label: t.nav.lieux },
  { href: `${homeHref}#ambiance`, label: t.nav.ambiance },
  { href: `${base}${localePrefix}guide/se-deplacer`, label: t.nav.seDeplacer },
];

const currentPath = Astro.url.pathname;

const otherLocale = locale === 'fr' ? 'en' : 'fr';
const pathNoBase = currentPath.startsWith(base) ? currentPath.slice(base.length) : currentPath;
const neutralPath = pathNoBase.replace(/^en\/?/, '');
const langSwitchHref = getRelativeLocaleUrl(otherLocale, neutralPath);
const langSwitchLabel = otherLocale === 'en' ? 'EN' : 'FR';
const langSwitchFull = otherLocale === 'en' ? 'English' : 'Français';
---

<input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
<header class="site-header">
  <div class="container">
    <a class="site-logo" href={homeHref}>
      <img src={`${base}logo/logo-mark.png`} alt="Mon Voyage à Paris" width="71" height="72" />
      <span class="site-logo-title-header">Mon Voyage<br />à Paris</span>
    </a>
    <label for="nav-toggle" class="nav-toggle" aria-label="Ouvrir le menu">
      <span></span><span></span><span></span>
    </label>
    <nav>
      <ul class="site-nav">
        {nav.map((item) => {
          const isActive = item.href.includes('/guide/') && currentPath.includes('/guide/');
          return (
            <li>
              <a href={item.href} class={isActive ? 'is-active' : ''}>
                {item.label}
              </a>
            </li>
          );
        })}
        <li>
          <a href={langSwitchHref} class="lang-switch" aria-label={langSwitchFull}>
            <svg class="lang-switch-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <circle cx="12" cy="12" r="10" />
              <path d="M2 12h20" />
              <path d="M12 2a15 15 0 0 1 0 20a15 15 0 0 1 0-20" />
            </svg>
            {langSwitchLabel}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('nav-toggle');
    if (!toggle) return;
    toggle.checked = false;
    document.body.classList.remove('nav-open');
    toggle.addEventListener('change', () => {
      document.body.classList.toggle('nav-open', toggle.checked);
    });
    document.querySelectorAll('.site-nav a').forEach((a) => {
      a.addEventListener('click', () => {
        toggle.checked = false;
        document.body.classList.remove('nav-open');
      });
    });
  });
</script>
