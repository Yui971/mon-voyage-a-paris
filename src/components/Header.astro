---
const base = import.meta.env.BASE_URL;

const nav = [
  { href: `${base}#lieux`, label: 'Les lieux' },
  { href: `${base}#ambiance`, label: 'Ambiance' },
  { href: `${base}guide/se-deplacer`, label: 'Se déplacer' },
];

const currentPath = Astro.url.pathname;
---

<div class="site-nav-root">
  <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
  <header class="site-header">
    <div class="container">
      <a class="site-logo" href={base}>
        <img src={`${base}logo/logo-mark.png`} alt="Mon Voyage à Paris" width="56" height="57" />
      </a>
      <label for="nav-toggle" class="nav-toggle" aria-label="Ouvrir le menu">
        <span></span><span></span><span></span>
      </label>
    </div>
  </header>
  <nav>
    <div class="container nav-inner">
    <ul class="site-nav">
      {nav.map((item) => {
        const isActive = item.href.includes('/guide/') && currentPath.includes('/guide/');
        return (
          <li>
            <a href={item.href} class={isActive ? 'is-active' : ''}>
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
    </div>
  </nav>
</div>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('nav-toggle');
    if (!toggle) return;
    toggle.checked = false;
    document.body.classList.remove('nav-open');
    toggle.addEventListener('change', () => {
      document.body.classList.toggle('nav-open', toggle.checked);
    });
    document.querySelectorAll('.site-nav a').forEach((a) => {
      a.addEventListener('click', () => {
        toggle.checked = false;
        document.body.classList.remove('nav-open');
      });
    });
  });
</script>
